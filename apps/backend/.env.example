# Local-only backend configuration. Copy to apps/backend/.env for local runs.
# Do not put production credentials in this file.

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/eshop
POSTGRES_MAINTENANCE_DATABASE=postgres
PORT=9000

STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

JWT_SECRET=local-dev-jwt-secret-change-me
COOKIE_SECRET=local-dev-cookie-secret-change-me

GOOGLE_OAUTH_CLIENT_ID=placeholder-local-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=placeholder-local-google-client-secret
VK_ID_CLIENT_ID=placeholder-local-vk-client-id
VK_ID_CLIENT_SECRET=placeholder-local-vk-client-secret

YOOKASSA_MODE=mock
YOOKASSA_SHOP_ID=placeholder-local-yookassa-shop-id
YOOKASSA_SECRET_KEY=placeholder-local-yookassa-secret-key
YOOKASSA_WEBHOOK_SECRET=placeholder-local-yookassa-webhook-secret

EMAIL_PROVIDER=mock
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=placeholder-local-smtp-user
SMTP_PASSWORD=placeholder-local-smtp-password
